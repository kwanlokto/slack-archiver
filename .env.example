# --- Required ---
# Password gating the setup wizard and all admin endpoints. Pick something strong.
ADMIN_PASSWORD=change-me

# --- Optional: pre-set Slack token (skips the wizard) ---
# If set, this xoxp- user token is used at startup. Must belong to a Workspace Owner.
# Leave blank to use the wizard at /setup.html instead — recommended.
SLACK_TOKEN=

# --- Storage ---
DB_PATH=./data/archive.db
# Defaults to <dir of DB_PATH>/credentials.json. Stores client_id, client_secret, and the OAuth token.
# CREDENTIALS_PATH=./data/credentials.json
EXPORT_DIR=./exports

# --- Scheduler ---
# How often the daemon pulls new messages. Default: every 10 minutes.
SCHEDULE_CRON=*/10 * * * *

# --- HTTP server ---
API_PORT=3000
API_HOST=127.0.0.1
# This must match exactly one of the "Redirect URLs" entries in your Slack app.
# Default uses 127.0.0.1 since API_HOST defaults to loopback.
# OAUTH_REDIRECT_URI=http://127.0.0.1:3000/api/setup/callback
