# Slack User OAuth Token (xoxp-...) — MUST belong to a Workspace Owner or Primary Owner.
# Required scopes:
#   channels:history, channels:read
#   groups:history,   groups:read
#   im:history,       im:read         (optional, for DMs)
#   mpim:history,     mpim:read       (optional, for group DMs)
#   users:read
#   team:read
SLACK_TOKEN=xoxp-your-token-here

# SQLite database file path
DB_PATH=./data/archive.db

# Where exported channel files are written
EXPORT_DIR=./exports

# How often the scheduler wakes up to pull new messages (cron expression).
# Default: every 10 minutes.
SCHEDULE_CRON=*/10 * * * *

# REST API + Web UI
API_PORT=3000
API_HOST=127.0.0.1

# Password required to modify state via the API/UI (add/remove channels, trigger runs).
# Sent as the `x-admin-password` header. Read endpoints are open by default.
ADMIN_PASSWORD=change-me
